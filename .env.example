# ─────────────────────────────────────────────────────────────────
# MockSim — environment configuration
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
MOCKSIM_HOST=0.0.0.0
MOCKSIM_PORT=8080

# ── Database ─────────────────────────────────────────────────────
# Local docker-compose:
DATABASE_URL=postgresql+asyncpg://mocksim:mocksim@localhost:5432/mocksim
# Cloud SQL (staging/prod): replace with actual connection string from GCP Secret Manager

# ── Trazmo integration ───────────────────────────────────────────
# Default webhook base URL — where MockSim POSTs events to Trazmo.
# This is the fallback. Per-tenant subscriptions (POST /pos/webhooks/subscriptions)
# override this for individual tenants.
# Use host.docker.internal when MockSim runs in docker-compose and
# trazmo-platform runs natively on the host. (Literal "localhost" is blocked
# by the SSRF guard.) On Linux without Docker Desktop add
# `extra_hosts: ["host.docker.internal:host-gateway"]` to docker-compose.yml.
TRAZMO_WEBHOOK_BASE_URL=http://host.docker.internal:8000
TRAZMO_POS_WEBHOOK_PATH=/webhooks/pos
TRAZMO_BANK_WEBHOOK_PATH=/webhooks/bank

# ── Security ─────────────────────────────────────────────────────
# Secret used to sign outbound webhook payloads (HMAC-SHA256).
# Trazmo verifies this on inbound webhooks.
WEBHOOK_SIGNING_SECRET=change-me-to-a-random-32-char-string

# Admin API token — required for all /admin/* endpoints.
MOCKSIM_ADMIN_TOKEN=change-me-admin-token

# Allow HTTP webhook targets (dev only). Set false in prod.
MOCKSIM_ALLOW_HTTP=true

# ── Active regions ───────────────────────────────────────────────
# Comma-separated list of ISO 3166-1 alpha-2 codes.
# Supported: PK, AE, SA, EG, BH
ENABLED_REGIONS=PK

# ── Webhook delivery ─────────────────────────────────────────────
DEFAULT_WEBHOOK_TIMEOUT_SECONDS=10
# Retry schedule in seconds (7 attempts before dead-letter)
WEBHOOK_RETRY_SCHEDULE=60,300,900,3600,21600,86400,86400

# ── Rate limits (requests per second) ───────────────────────────
POS_API_TPS_LIMIT=50
BANK_API_TPS_LIMIT=50
ADMIN_API_TPS_LIMIT=20

# ── Sim clock behavior ───────────────────────────────────────────
# How many sim-days each advance() slice processes at a time
SIM_CLOCK_ADVANCE_SLICE_DAYS=1
# Wall-clock budget (seconds) per slice before returning 202 Accepted
SIM_CLOCK_ADVANCE_BUDGET_SECONDS=30
# Advances over this many sim-days always return 202 immediately
SIM_CLOCK_ADVANCE_ASYNC_THRESHOLD_DAYS=7

# ── Observability ────────────────────────────────────────────────
LOG_LEVEL=INFO
# OTLP endpoint for OpenTelemetry traces (e.g. Jaeger in docker-compose)
# OTLP_ENDPOINT=http://localhost:4317

# ── Trazmo integration (Phase H — authenticated service API) ────
# Cross-system onboarding talks to trazmo's
# /api/v1/_internal/mocksim/* surface. The token must match trazmo's
# MOCKSIM_SERVICE_TOKEN env var; rotate both together. Empty values =
# the cross-system flow is disabled (MockSim still works standalone).
TRAZMO_API_URL=http://host.docker.internal:8000
TRAZMO_SERVICE_TOKEN=change-me-shared-with-trazmo-min-32-chars
# Direct-PG path — deprecated, only seed_e2e.py still uses it for the
# initial trazmo bootstrap (subprocess invocation of trazmo's seeds).
TRAZMO_DATABASE_URL=postgresql://trazmo:trazmo@host.docker.internal:5433/trazmo_platform

# ── ngrok (local dev only) ───────────────────────────────────────
# Uncomment to enable ngrok sidecar in docker-compose
# NGROK_AUTHTOKEN=your-ngrok-auth-token
